{
  "pcweb_id": "PCWEB-084",
  "policy_name": "Desktop Cargo Check Artifact Policy",
  "policy_status": "cargo_check_artifact_policy_only",
  "default_quality_gate_status": "included_in_root_pytest",
  "cargo_check_execution_status": "not_run",
  "external_command_execution_status": "not_run",
  "safe_to_run_cargo_check_now": false,
  "safe_to_install_toolchain_now": false,
  "safe_to_fetch_dependencies_now": false,
  "safe_to_generate_cargo_lock_now": false,
  "safe_to_generate_target_dir_now": false,
  "safe_to_run_tauri_dev_now": false,
  "safe_to_run_tauri_build_now": false,
  "safe_to_read_configs_local_now": false,
  "cargo_lock_policy": {
    "status": "generated_after_pcweb_118_controlled_check",
    "path": "code/desktop_tauri/src-tauri/Cargo.lock",
    "post_approval_action": "keep_committed_for_desktop_app_reproducibility",
    "reason": "Desktop app reproducibility: once a first approved dependency-resolution run creates Cargo.lock, keep it as an app artifact."
  },
  "cargo_target_dir_policy": {
    "status": "created_under_ignored_artifacts_after_pcweb_118_controlled_check",
    "path": "artifacts/tmp/desktop_tauri_target",
    "must_be_under_ignored_path": true,
    "reason": "Keep Cargo build output out of source directories and under the already ignored artifacts/tmp area."
  },
  "network_dependency_fetch_policy": {
    "status": "blocked_by_default",
    "first_approved_fetch_scope": "cargo_crates_only",
    "repeat_check_mode": "locked_offline_after_lock_and_cache",
    "reason": "A first approved dependency-resolution run may need crates.io access; repeat checks should prefer --locked --offline after lock/cache exist."
  },
  "cleanup_policy": {
    "status": "decided_not_executed",
    "disposable_paths": [
      "artifacts/tmp/desktop_tauri_target"
    ],
    "must_not_remove_paths": [
      "code/desktop_tauri/src-tauri/Cargo.toml",
      "code/desktop_tauri/src-tauri/Cargo.lock",
      "code/desktop_tauri/src-tauri/src",
      "code/desktop_tauri/src-tauri/tauri.conf.json"
    ]
  },
  "future_first_approved_cargo_check": {
    "status": "executed_once_in_pcweb_118_controlled_check",
    "command": [
      "cargo",
      "check",
      "--manifest-path",
      "code/desktop_tauri/src-tauri/Cargo.toml"
    ],
    "env": {
      "CARGO_TARGET_DIR": "artifacts/tmp/desktop_tauri_target"
    }
  },
  "future_repeat_locked_offline_cargo_check": {
    "status": "candidate_ready_after_pcweb_118_lock_and_cache",
    "command": [
      "cargo",
      "check",
      "--manifest-path",
      "code/desktop_tauri/src-tauri/Cargo.toml",
      "--locked",
      "--offline"
    ],
    "env": {
      "CARGO_TARGET_DIR": "artifacts/tmp/desktop_tauri_target"
    }
  },
  "allowed_future_artifacts_after_explicit_approval": [
    "code/desktop_tauri/src-tauri/Cargo.lock",
    "artifacts/tmp/desktop_tauri_target"
  ],
  "forbidden_source_tree_artifacts": [
    "code/desktop_tauri/src-tauri/target",
    "code/desktop_tauri/node_modules",
    "code/desktop_tauri/dist",
    "code/desktop_tauri/bundle",
    "code/desktop_tauri/package.json",
    "code/desktop_tauri/package-lock.json",
    "code/desktop_tauri/pnpm-lock.yaml",
    "code/desktop_tauri/yarn.lock"
  ],
  "forbidden_commands": [
    ["cargo", "build"],
    ["cargo", "tauri", "dev"],
    ["cargo", "tauri", "build"],
    ["npm", "install"],
    ["npm", "ci"],
    ["pnpm", "install"],
    ["yarn", "install"],
    ["npm", "run", "tauri", "dev"],
    ["npm", "run", "tauri", "build"],
    ["pnpm", "run", "tauri", "dev"],
    ["pnpm", "run", "tauri", "build"],
    ["yarn", "tauri", "dev"],
    ["yarn", "tauri", "build"],
    ["npx", "tauri", "dev"],
    ["npx", "tauri", "build"]
  ],
  "forbidden_default_side_effects": [
    "audio_permission_request",
    "audio_device_enumeration",
    "microphone_capture",
    "system_audio_capture",
    "asr_worker_spawn",
    "provider_config_read",
    "secret_read",
    "configs_local_read",
    "remote_asr_call",
    "remote_llm_call",
    "installer_creation",
    "signing",
    "notarization"
  ],
  "remaining_preconditions_before_first_cargo_check": [
    "explicit_user_approval_for_first_cargo_check",
    "rust_toolchain_available",
    "first_dependency_resolution_network_fetch_approved_or_cache_preseeded",
    "cargo_lock_policy_acknowledged",
    "cargo_target_dir_policy_acknowledged",
    "cleanup_policy_acknowledged",
    "no_audio_worker_secret_remote_boundary_reconfirmed"
  ],
  "official_sources": [
    {
      "label": "Cargo check command",
      "url": "https://doc.rust-lang.org/cargo/commands/cargo-check.html"
    },
    {
      "label": "Cargo build cache",
      "url": "https://doc.rust-lang.org/cargo/reference/build-cache.html"
    },
    {
      "label": "Cargo environment variables",
      "url": "https://doc.rust-lang.org/cargo/reference/environment-variables.html"
    },
    {
      "label": "Cargo.toml vs Cargo.lock",
      "url": "https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html"
    },
    {
      "label": "Tauri v2 prerequisites",
      "url": "https://v2.tauri.app/start/prerequisites/"
    }
  ]
}
