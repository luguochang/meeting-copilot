{
  "pcweb_id": "PCWEB-083",
  "policy_name": "Desktop Build Readiness Policy",
  "policy_status": "build_readiness_policy_only",
  "default_quality_gate_status": "included_in_root_pytest",
  "toolchain_probe_mode": "toolchain_version_probe_only",
  "dependency_install_status": "not_run",
  "build_execution_status": "not_run",
  "tauri_cli_execution_status": "not_run",
  "safe_to_probe_toolchain_versions_now": true,
  "safe_to_run_cargo_check_now": false,
  "safe_to_run_tauri_dev_now": false,
  "safe_to_run_tauri_build_now": false,
  "safe_to_install_dependencies_now": false,
  "safe_to_generate_lockfiles_now": false,
  "safe_to_generate_build_artifacts_now": false,
  "allowed_probe_commands": [
    ["rustc", "--version"],
    ["cargo", "--version"]
  ],
  "forbidden_commands": [
    ["cargo", "check"],
    ["cargo", "build"],
    ["cargo", "tauri", "dev"],
    ["cargo", "tauri", "build"],
    ["npm", "install"],
    ["npm", "ci"],
    ["pnpm", "install"],
    ["yarn", "install"],
    ["npm", "run", "tauri", "dev"],
    ["npm", "run", "tauri", "build"],
    ["pnpm", "run", "tauri", "dev"],
    ["pnpm", "run", "tauri", "build"],
    ["yarn", "tauri", "dev"],
    ["yarn", "tauri", "build"],
    ["npx", "tauri", "dev"],
    ["npx", "tauri", "build"]
  ],
  "future_build_check_candidate": [
    "cargo",
    "check",
    "--manifest-path",
    "code/desktop_tauri/src-tauri/Cargo.toml"
  ],
  "future_build_check_status": "blocked_until_preconditions_pass",
  "required_future_preconditions": [
    "explicit_user_approval_for_build_artifacts",
    "cargo_lock_policy_decided",
    "target_dir_policy_decided",
    "network_dependency_fetch_policy_decided",
    "cache_cleanup_policy_decided",
    "no_audio_worker_secret_remote_boundary_reconfirmed"
  ],
  "forbidden_default_artifacts": [
    "code/desktop_tauri/src-tauri/Cargo.lock",
    "code/desktop_tauri/src-tauri/target",
    "code/desktop_tauri/package.json",
    "code/desktop_tauri/package-lock.json",
    "code/desktop_tauri/pnpm-lock.yaml",
    "code/desktop_tauri/yarn.lock",
    "code/desktop_tauri/node_modules",
    "code/desktop_tauri/dist",
    "code/desktop_tauri/bundle",
    "code/desktop_tauri/src-tauri/target/release/bundle"
  ],
  "forbidden_default_side_effects": [
    "audio_permission_request",
    "audio_device_enumeration",
    "microphone_capture",
    "system_audio_capture",
    "asr_worker_spawn",
    "provider_config_read",
    "secret_read",
    "configs_local_read",
    "remote_asr_call",
    "remote_llm_call",
    "installer_creation",
    "signing",
    "notarization"
  ],
  "official_sources": [
    {
      "label": "Tauri v2 prerequisites",
      "url": "https://v2.tauri.app/start/prerequisites/"
    },
    {
      "label": "Tauri v2 CLI reference",
      "url": "https://v2.tauri.app/reference/cli/"
    },
    {
      "label": "Tauri v2 configuration files",
      "url": "https://v2.tauri.app/develop/configuration-files/"
    }
  ]
}
