# Meeting Copilot — environment template.
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored. Never commit real secrets.

# LLM gateway (OpenAI-compatible). Used by code/asr_runtime/scripts/meeting_analysis.py
# and (Phase 2-3) the web_mvp backend LLM service.
LLM_GATEWAY_BASE_URL=https://your-gateway.example.com
LLM_GATEWAY_API_KEY=sk-replace-me
LLM_GATEWAY_MODEL=gpt-5.5
LLM_GATEWAY_TIMEOUT_SECONDS=60
